<?xml version="1.0" encoding="UTF-8"?>

<!--
  TODO exercice 2 (étape 0) : écrire la vue FXML du compteur, de zéro.

  Vous partez (presque) d'une page blanche : à l'exercice 1 vous aviez la racine
  et les imports, ici vous écrivez tout.

  Spécifications de la vue à produire :

  1. Imports à ajouter en tête de fichier (un par balise <?import ...?>) :
       Insets, Label, Button, BorderPane (ou VBox), HBox, VBox.

  2. Racine : un BorderPane (ou un VBox) avec :
       - xmlns="http://javafx.com/javafx/25"
       - xmlns:fx="http://javafx.com/fxml/1"
       - fx:controller="fr.univ_amu.iut.exercice2.CompteurController"
       - prefWidth / prefHeight raisonnables (ex : 360 x 220).
       - 20 px de padding via <padding><Insets .../></padding>.

  3. Contenu centré (dans <center> si BorderPane), espacé verticalement.
     Trois zones de haut en bas :

       a. Un Label fx:id="labelCompteur" text="0" en police 48 px gras (utilisez
          un attribut style="-fx-font-size: 48px; -fx-font-weight: bold;").

       b. Un HBox horizontal (spacing 10, alignment CENTER) qui contient deux
          Button côte à côte :
            - fx:id="boutonDecrementer"  text="−"  onAction="#decrementer"
            - fx:id="boutonIncrementer"  text="+"  onAction="#incrementer"

       c. Un Button fx:id="boutonReinitialiser" text="Réinitialiser" onAction="#reinitialiser".

  Référez-vous au FXML de l'exercice 1 et à la section "Cheat-sheet FXML" du
  README pour la syntaxe. Les attributs fx:controller / fx:id / onAction sont
  nouveaux à cet exercice : ils créent les ponts qui seront exploités côté
  contrôleur (à l'étape 1).
-->


<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
     fx:controller="fr.univ_amu.iut.exercice2.CompteurController"
     prefWidth="360.0" prefHeight="220.0" spacing="10" BorderPane.alignment="CENTER">

     <padding>
          <Insets top="20" right="20" bottom="20" left="20" />
     </padding>


     <Label fx:id="labelCompteur" text="0" style="-fx-font-size: 48px; -fx-font-weight: bold;" />
     <HBox spacing="10" BorderPane.alignment="CENTER">
          <Button fx:id="boutonDecrementer" text="−" onAction="#decrementer" />
          <Button fx:id="boutonIncrementer" text="+" onAction="#incrementer" />
     </HBox>
     <Button fx:id="boutonReinitialiser" text="Réinitialiser" onAction="#reinitialiser" />


</VBox>


      